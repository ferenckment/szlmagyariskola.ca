---
import Base from '../layouts/Base.astro';
---

<Base title="Az oldal nem található / Page not found">
  <div class="container container--narrow prose" style="text-align: center; padding-block: 4rem;">
    <h1>Az oldal nem található</h1>
    <p>A keresett oldal nem létezik vagy elköltözött.</p>
    <p lang="en">The page you are looking for does not exist or has moved.</p>
    <p>
      <a class="btn" href="/hu/">Vissza a kezdőlapra</a>
      &nbsp;
      <a class="btn" href="/en/" lang="en">Back to the homepage</a>
    </p>
  </div>
</Base>
