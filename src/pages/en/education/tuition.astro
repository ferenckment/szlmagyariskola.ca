---
import Base from '../../../layouts/Base.astro';
---

<Base title="Tuition & Registration" lang="en" description="Tuition and registration at the Szent László Hungarian School.">
  <div class="container container--narrow prose">
    <h1 class="page-title">Tuition & Registration</h1>

    <h3>Tuition</h3>
    <p>For the 2022/23 school year, tuition is <strong>$80</strong> per child.</p>
    <p>
      Sibling discount: <strong>$60</strong> per child for two children,
      <strong>$50</strong> per child for three children.
    </p>
    <p>
      Tuition is paid in a single installment at registration; please send payments
      by e-transfer to
      <a href="mailto:szlmagyariskola@gmail.com"><strong>szlmagyariskola@gmail.com</strong></a>.
    </p>

    <div class="info-box">
      <h3 style="margin-top: 0;">Registration</h3>
      <p>
        <a class="btn" href="/docs/jelentkezesi-lap-2022-23.pdf" download>
          Download the registration form (PDF, in Hungarian)
        </a>
      </p>
      <p style="margin-bottom: 0;">
        Please send the completed registration form to
        <a href="mailto:szlmagyariskola@gmail.com">szlmagyariskola@gmail.com</a>.
      </p>
    </div>
  </div>
</Base>
