---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'hu' | 'en';
}

const defaultDesc = {
  hu: 'A vancouveri Szent László Magyar Iskola hivatalos oldala. Magyar nyelvoktatás gyerekeknek és felnőtteknek 1960 óta.',
  en: 'Official site of the Szent László Hungarian School in Vancouver. Hungarian language education for children and adults since 1960.',
};

const { title, lang = 'hu', description = defaultDesc[lang] } = Astro.props;

const navByLang = {
  hu: [
    { text: 'Kezdőlap', href: '/hu' },
    {
      text: 'Rólunk', href: '/hu/about',
      children: [{ text: 'Segítőink', href: '/hu/about/volunteers' }],
    },
    {
      text: 'Oktatás', href: '/hu/education',
      children: [
        { text: 'Tanáraink', href: '/hu/education/teachers' },
        { text: 'Tantermeink', href: '/hu/education/classrooms' },
        { text: 'Csoportjaink', href: '/hu/education/groups' },
        { text: 'Órarend', href: '/hu/education/schedule' },
        { text: 'Tandíj, jelentkezés', href: '/hu/education/tuition' },
      ],
    },
    {
      text: 'Táborok', href: '/hu/camps',
      children: [
        { text: '2019', href: '/hu/camps/2019' },
        { text: '2022', href: '/hu/camps/2022' },
      ],
    },
    {
      text: 'Hírek, Események', href: '/hu/news',
      children: [{ text: 'Naptár', href: '/hu/news/calendar' }],
    },
    { text: 'Elérhetőség', href: '/hu/contact' },
  ],
  en: [
    { text: 'Home', href: '/en' },
    {
      text: 'About Us', href: '/en/about',
      children: [{ text: 'Our Volunteers', href: '/en/about/volunteers' }],
    },
    {
      text: 'Education', href: '/en/education',
      children: [
        { text: 'Our Teachers', href: '/en/education/teachers' },
        { text: 'Our Classrooms', href: '/en/education/classrooms' },
        { text: 'Our Groups', href: '/en/education/groups' },
        { text: 'Schedule', href: '/en/education/schedule' },
        { text: 'Tuition & Registration', href: '/en/education/tuition' },
      ],
    },
    {
      text: 'Camps', href: '/en/camps',
      children: [
        { text: '2019', href: '/en/camps/2019' },
        { text: '2022', href: '/en/camps/2022' },
      ],
    },
    {
      text: 'News & Events', href: '/en/news',
      children: [{ text: 'Calendar', href: '/en/news/calendar' }],
    },
    { text: 'Contact', href: '/en/contact' },
  ],
};

const ui = {
  hu: {
    brandName: 'Szent László Magyar Iskola',
    brandSub: 'Vancouver · Alapítva 1960',
    navLabel: 'Fő navigáció',
    menuLabel: 'Menü',
    founded: 'Alapítva: 1960',
    titleSuffix: 'Szent László Magyar Iskola, Vancouver',
  },
  en: {
    brandName: 'Szent László Hungarian School',
    brandSub: 'Vancouver · Founded 1960',
    navLabel: 'Main navigation',
    menuLabel: 'Menu',
    founded: 'Founded: 1960',
    titleSuffix: 'Szent László Hungarian School, Vancouver',
  },
}[lang];

const nav = navByLang[lang];

const currentPath = decodeURIComponent(Astro.url.pathname).replace(/\/$/, '') || '/';

// the same page in the other language: swap the /hu | /en prefix
const rest = currentPath.replace(/^\/(hu|en)/, '');
const huHref = '/hu' + rest || '/hu';
const enHref = '/en' + rest || '/en';

// 'page' on the exact page; 'true' on a parent whose child page is open.
// Language roots ('/hu', '/en') never count as parents, or Home would always light up.
const langRoots = ['/', '/hu', '/en'];
const currentAttr = (href: string) =>
  currentPath === href
    ? 'page'
    : !langRoots.includes(href) && currentPath.startsWith(href + '/')
      ? 'true'
      : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} – {ui.titleSuffix}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" hreflang="hu" href={huHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;600;700&family=Open+Sans:wght@400;600;700&family=Alegreya+Sans+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-brand" href={`/${lang}/`}>
          <img class="site-brand__herma" src="/images/szent-laszlo-herma.png" alt="Szent László herma" />
          <span>
            {ui.brandName}
            <small>{ui.brandSub}</small>
          </span>
        </a>

        <input type="checkbox" id="nav-toggle" class="nav-toggle" />
        <label for="nav-toggle" class="nav-toggle-label" aria-label={ui.menuLabel}>☰</label>

        <div class="header-end">
        <nav class="site-nav" aria-label={ui.navLabel}>
          <ul>
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={currentAttr(item.href)}
                >{item.text}</a>
                {item.children && (
                  <ul class="submenu">
                    {item.children.map((sub) => (
                      <li>
                        <a
                          href={sub.href}
                          aria-current={currentPath === sub.href ? 'page' : undefined}
                        >{sub.text}</a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>

        <div class="lang-switch">
          <a class:list={['lang-switch__item', { 'is-active': lang === 'hu' }]} href={huHref} title="Magyar">
            <img src="/images/flags/flag-hu.svg" alt="Magyar" />
          </a>
          <a class:list={['lang-switch__item', { 'is-active': lang === 'en' }]} href={enHref} title="English">
            <img src="/images/flags/flag-ca.svg" alt="English" />
          </a>
        </div>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div>
          <strong>{ui.brandName}</strong><br />
          1810 East 7th Avenue, Vancouver, B.C. V5N 1S2
        </div>
        <div>
          <a href="mailto:szlmagyariskola@gmail.com">szlmagyariskola@gmail.com</a><br />
          {ui.founded}
        </div>
      </div>
    </footer>
  </body>
</html>
