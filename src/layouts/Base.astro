---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A vancouveri Szent László Magyar Iskola hivatalos oldala. Magyar nyelvoktatás gyerekeknek és felnőtteknek 1960 óta.' } = Astro.props;

const nav = [
  { text: 'Kezdőlap', href: '/' },
  {
    text: 'Rólunk', href: '/about',
    children: [{ text: 'Segítőink', href: '/about/volunteers' }],
  },
  {
    text: 'Oktatás', href: '/education',
    children: [
      { text: 'Tanáraink', href: '/education/teachers' },
      { text: 'Tantermeink', href: '/education/classrooms' },
      { text: 'Csoportjaink', href: '/education/groups' },
      { text: 'Órarend', href: '/education/schedule' },
      { text: 'Tandíj, jelentkezés', href: '/education/tuition' },
    ],
  },
  {
    text: 'Táborok', href: '/camps',
    children: [
      { text: '2019', href: '/camps/2019' },
      { text: '2022', href: '/camps/2022' },
    ],
  },
  {
    text: 'Hírek, Események', href: '/news',
    children: [{ text: 'Naptár', href: '/news/calendar' }],
  },
  { text: 'Elérhetőség', href: '/contact' },
];

const currentPath = decodeURIComponent(Astro.url.pathname).replace(/\/$/, '') || '/';

// 'page' on the exact page; 'true' on a parent whose child page is open
const currentAttr = (href: string) =>
  currentPath === href
    ? 'page'
    : href !== '/' && currentPath.startsWith(href + '/')
      ? 'true'
      : undefined;
---

<!doctype html>
<html lang="hu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} – Szent László Magyar Iskola, Vancouver</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;600;700&family=Open+Sans:wght@400;600;700&family=Alegreya+Sans+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-brand" href="/">
          <img class="site-brand__herma" src="/images/szent-laszlo-herma.png" alt="Szent László herma" />
          <span>
            Szent László Magyar Iskola
            <small>Vancouver · Alapítva 1960</small>
          </span>
        </a>

        <input type="checkbox" id="nav-toggle" class="nav-toggle" />
        <label for="nav-toggle" class="nav-toggle-label" aria-label="Menü">☰</label>

        <nav class="site-nav" aria-label="Fő navigáció">
          <ul>
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={currentAttr(item.href)}
                >{item.text}</a>
                {item.children && (
                  <ul class="submenu">
                    {item.children.map((sub) => (
                      <li>
                        <a
                          href={sub.href}
                          aria-current={currentPath === sub.href ? 'page' : undefined}
                        >{sub.text}</a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div>
          <strong>Szent László Magyar Iskola</strong><br />
          1810 East 7th Avenue, Vancouver, B.C. V5N 1S2
        </div>
        <div>
          <a href="mailto:szlmagyariskola@gmail.com">szlmagyariskola@gmail.com</a><br />
          Alapítva: 1960
        </div>
      </div>
    </footer>
  </body>
</html>
